{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Dictosaurus",
  "version": "0.1.0",
  "identifier": "com.dictosaurus.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Dictosaurus",
        "width": 820,
        "height": 720,
        "minWidth": 660,
        "minHeight": 540,
        "visible": false,
        "backgroundColor": "#F5F5F7"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
