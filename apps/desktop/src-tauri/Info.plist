<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- TCC reads the embedded __TEXT,__info_plist for non-.app runs (`tauri dev`).
	     Without CFBundleIdentifier the microphone usage key is treated as missing. -->
	<key>CFBundleIdentifier</key>
	<string>com.dictosaurus.desktop</string>
	<key>CFBundleExecutable</key>
	<string>dictosaurus</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Dictosaurus needs microphone access to transcribe your dictation on-device.</string>
</dict>
</plist>
